# Copy this file to ".env" and fill in your values

# MongoDB connection string (MongoDB Atlas recommended)
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/ethnicluxury
MONGODB_URI=

# Optional: override the DB name when your URI has no default db
# MONGODB_DB=ethnicluxury

# Port for the server
PORT=3000

# Admin password for logging into /admin (POST /api/login)
ADMIN_PASSWORD=abrarisbest

# Token that admin requests must include in 'x-admin-token' header
ADMIN_TOKEN=replace-with-random-secret
